# Chloe — environment template
# Copy this file to `.env` and fill in your own values.
# DO NOT commit your real .env (it's in .gitignore).

# ─── REQUIRED ───────────────────────────────────────────────────────────────

# Groq API key — powers chat (Llama 3.3 70B) and STT (Whisper).
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=

# ─── TTS (optional — at least one path needs to work) ───────────────────────

# ElevenLabs — best voice quality, opt-in to avoid burning credits.
# Set USE_ELEVENLABS=1 to enable. Get a key at https://elevenlabs.io
USE_ELEVENLABS=0
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Local Kokoro TTS — high-quality, offline, free.
# Set USE_KOKORO=1 to enable; downloads model on first run.
USE_KOKORO=0

# Edge TTS is the always-available fallback. Override the voice if you like.
# Suggested: en-US-AriaNeural, en-US-JennyNeural, en-GB-SoniaNeural
EDGE_TTS_VOICE=en-US-AriaNeural

# ─── Wake word (optional — Porcupine alternative to OpenWakeWord) ──────────
PORCUPINE_ACCESS_KEY=

# ─── Bitcoin Lightning Wallet (optional) ───────────────────────────────────

# Breez SDK API key — get one free at
# https://breez.technology/request-api-key/
BREEZ_API_KEY=

# Where wallet seed + state are stored. Default: C:\Chloe\secrets
CHLOE_WALLET_SECRETS_DIR=

# ─── Routing (chat path) ────────────────────────────────────────────────────

# 1 = local-first (Ollama handles everyday chat, Groq compound for search)
# 0 = cloud-first (Groq fast → hedge → compound → Ollama on failure)
# Flip to 0 for demo recording (~1s response vs ~20s).
CHLOE_OLLAMA_PRIMARY=1
CHLOE_OLLAMA_FALLBACK=1

# Ollama model to use (must already be pulled via `ollama pull`)
OLLAMA_MODEL=llama3.1:8b

# Groq compound search — set to 0 to disable real-time web queries.
CHLOE_USE_COMPOUND=1

# ─── Voice / mic tuning ─────────────────────────────────────────────────────

# Mic device override. Numeric index OR substring of device name.
# Leave blank for system-default WASAPI mic. Examples:
#   CHLOE_MIC=15
#   CHLOE_MIC=Samson
CHLOE_MIC=

# Software gain multiplier (1.0 = no boost; quiet mics may want 2.0–3.0)
CHLOE_MIC_GAIN=1.0

# Wake-word sensitivity (0.0–1.0, higher = stricter, fewer false triggers)
WAKE_THRESHOLD=0.5

# Silence detection threshold — RMS below this is treated as silence.
CHLOE_SILENCE_RMS=0.002

# How long to wait after silence before stopping recording (ms).
SILENCE_HANG_MS=2000

# Hard cap on how long a single recording can run (s).
MAX_RECORD_S=60

# Push-to-talk hold timeout (s).
PTT_MAX_S=300

# How long the mic stays open after a reply for spontaneous follow-ups (s).
CHLOE_FOLLOWUP_S=5

# ─── Startup behavior ───────────────────────────────────────────────────────

# 1 = play boot sound and greeting on startup; 0 = silent boot.
GREETING_ENABLED=1
BOOT_SOUND_ENABLED=1

# Mode tag — appears in startup log. Useful for distinguishing dev/home/etc.
CHLOE_MODE=home
